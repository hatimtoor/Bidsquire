# ===========================================
# 🚀 Bidsquire Auction Platform - Environment Configuration
# ===========================================
# Copy this file to .env.production and update the values
# 
# Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 
# ===========================================

# 🔐 Security Settings
# ===========================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,yourdomain.com,www.yourdomain.com

# 🗄️ Database Configuration
# ===========================================
POSTGRES_DB=auctionflow
POSTGRES_USER=auctionuser
POSTGRES_PASSWORD=your_secure_database_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# 🔄 Redis Configuration (Caching & Sessions)
# ===========================================
REDIS_URL=redis://redis:6379

# 🌐 Frontend Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP/api
NEXT_PUBLIC_DB_HOST=postgres
NEXT_PUBLIC_DB_PORT=5432
NEXT_PUBLIC_DB_NAME=auctionflow
NEXT_PUBLIC_DB_USER=auctionuser
NEXT_PUBLIC_DB_PASSWORD=your_secure_database_password_here

# 👤 Admin User Configuration (Auto-created on first startup)
# ===========================================
ADMIN_NAME=Your Company Admin
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=YourSecureAdminPassword123!

# 🔗 External Integrations
# ===========================================
N8N_HIBID_WEBHOOK_URL=https://sorcer.app.n8n.cloud/webhook/789023dc-a9bf-459c-8789-d9d0c993d1cb
N8N_PHOTOGRAPHY_WEBHOOK_URL=https://sorcer.app.n8n.cloud/webhook/0be48928-c40c-4e16-a9f1-1e2fdf9ed9d2
# Paste the webhook URL from n8n after importing the ai-researcher.json workflow
N8N_AI_RESEARCH_WEBHOOK_URL=https://sorcer.app.n8n.cloud/webhook/your-ai-research-webhook-id

# Shared secret between Next.js and Django — generate a strong random string
# e.g. openssl rand -hex 32
INTERNAL_API_SECRET=change-this-to-a-strong-random-secret

# 🤖 AI & eBay API Keys
# ===========================================
# Anthropic API key — used by the n8n AI Research workflow
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# eBay Production API credentials (use Production keys, not Sandbox)
# Get yours at: https://developer.ebay.com/my/keys
# EBAY_CLIENT_ID  = "App ID" on the keys page
# EBAY_CLIENT_SECRET = "Cert ID" on the keys page
# EBAY_RUNAME = "Your app name — OAuth" RuName from the Auth Accepted URL section
# EBAY_APP_ID is used by the n8n AI research workflow (also the App ID / Client ID)
EBAY_APP_ID=YourApp-YourApp-PRD-xxxxxxxx-xxxxxxxx
EBAY_CLIENT_ID=YourApp-YourApp-PRD-xxxxxxxx-xxxxxxxx
EBAY_CLIENT_SECRET=PRD-xxxxxxxxxxxxxxxx-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EBAY_RUNAME=YourApp-YourApp-PRD-xxxxxxxx-xxxxxxxx

# 📧 Email Configuration (Optional)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# 🔒 SSL Configuration (Production)
# ===========================================
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 📊 Monitoring & Logging
# ===========================================
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-here

# 🚀 Performance Settings
# ===========================================
# Database connection pool settings
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30

# Redis cache settings
CACHE_TTL=3600
SESSION_TIMEOUT=86400

# ===========================================
# 📝 Quick Setup Instructions:
# ===========================================
# 1. Copy this file: cp env.example .env.production
# 2. Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 3. Update POSTGRES_PASSWORD with a strong password
# 4. Update ADMIN_EMAIL and ADMIN_PASSWORD
# 5. Update ALLOWED_HOSTS with your domain
# 6. Set ANTHROPIC_API_KEY (from console.anthropic.com)
# 7. Set EBAY_APP_ID, EBAY_CLIENT_ID, EBAY_CLIENT_SECRET, EBAY_RUNAME (from developer.ebay.com)
#    Register redirect URI: https://yourdomain.com/api/ebay/callback
# 8. Import n8n-workflows/ai-researcher.json into n8n, then set N8N_AI_RESEARCH_WEBHOOK_URL
# 9. Run: ./deploy-easy.sh (Linux/Mac) or .\deploy-easy.ps1 (Windows)
# ===========================================
